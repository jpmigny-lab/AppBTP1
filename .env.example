# Copier vers Vercel : Project → Settings → Environment Variables (Production + Preview).
#
# Front (build Vite — visibles côté navigateur, ne jamais y mettre la service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Vide = même origine que le site (recommandé sur Vercel)
VITE_API_BASE_URL=
#
# API serverless /api/team/* sur Vercel : ces clés DOIVENT exister (les VITE_* seuls peuvent ne pas suffire).
# Dupliquer URL + anon sans préfixe VITE_ évite les erreurs « création membre » en prod.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
TEAM_CODE_PEPPER=

# Optionnel (autres routes API)
ANTHROPIC_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Checklist prod (patron + équipe) ---
# [ ] Migrations SQL Supabase appliquées (user_profiles, team_members, …)
# [ ] Supabase Auth : Site URL + Redirect URLs = domaine Vercel
# [ ] Test patron : connexion → Équipe → créer membre (POST /api/team/member)
# [ ] Test employé : /team-login/{slug} + code → /team-dashboard
