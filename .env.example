# Copier vers les variables d’environnement du projet Vercel (Settings → Environment Variables).
# Front (exposées au navigateur — ne pas y mettre la service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Laisser vide si l’API est sur le même domaine que le front (déploiement Vercel standard)
VITE_API_BASE_URL=

# API serverless (/api/*) — jamais préfixer VITE_
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
TEAM_CODE_PEPPER=

# Optionnel (autres routes API)
ANTHROPIC_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
